msg() {
    local colors=(
        "\033[1;91m"  # red
        "\033[1;92m"  # green
        "\033[1;93m"  # yellow
        "\033[1;94m"  # blue
        "\033[1;95m"  # magenta
        "\033[1;96m"  # cyan
    )

    local reset="\033[0m"

    # random color pick
    local c=${colors[$RANDOM % ${#colors[@]}]}

    echo -e "${c}➤ $*${reset}" >&2
}
banner() {
    clear

    # random color
    colors=(
        "\033[1;91m" "\033[1;92m" "\033[1;93m"
        "\033[1;94m" "\033[1;95m" "\033[1;96m"
    )
    c=${colors[$RANDOM % ${#colors[@]}]}
    reset="\033[0m"

    echo -e "$c"
    
    if command -v figlet >/dev/null 2>&1; then
        figlet -f slant "Rooted Cyber"
    else
        echo "==== Rooted Cyber ===="
    fi

    echo -e "\033[1;92m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "        ⚡ AUTO SETUP TOOL ⚡"
    echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${reset}"
}
ff() {
rm -f $PREFIX/var/lib/dpkg/lock*
rm -f $PREFIX/var/lib/apt/lists/lock
rm -f $PREFIX/var/cache/apt/archives/lock
chmod +w ~/.zshrc
rm -f $PREFIX/var/lib/dpkg/lock*
dpkg --configure -a
apt --fix-broken install -y
chmod +w ~/.zshrc 2>/dev/null
dpkg --configure -a
}
ch() {
if [ -n "$PREFIX" ]; then
msg Termux found
cd ~/.abc
msg installing
msg
dpkg -i Termux.deb
else
msg ubuntu found
cd ~/.abc
msg installing
msg
dpkg -i Termux-ubuntu.deb
fi
}
gc() {
apt install --fix-broken -y
cd ~
if [ -e .abc  ];then
msg Already clone
cd ~/.abc
git pull
ch
else
cd ~
rm -rf ~/.abc
git clone https://github.com/rooted-cyber/setup2 .abc
ch
fi
}
a() {
banner
msg starting....
rm -f "$PREFIX/var/lib/dpkg/lock"* 2>/dev/null
ff
apt install --fix-broken -y
msg updating
msg 
apt update -y && apt upgrade -y
apt install --fix-broken -y
clear
for b in proot git wget figlet toilet python3 sudo;do
if command -v $b > /dev/null 2>&1;then
msg "already installed $b"
else
msg "installing \033[1;93m $b"
sleep 1
echo
apt install python-pip -y
apt install $b -y || msg not found
fi
done
apt install --fix-broken -y
#clear
gc 
cd ~
wget -O .bashrc https://github.com/rooted-cyber/Zsh-files/raw/main/.bashrc > /dev/null 2>&1
msg run this ➤ termux-setup-storage
}
a
sleep 1
h